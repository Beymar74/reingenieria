// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  username  String   @unique @db.VarChar(100)
  password  String   @db.VarChar(255)
  nombre    String   @db.VarChar(255)
  rol       String   @default("admin") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  @@map("usuarios")
}

model Tercero {
  idTercero String   @id @map("id_tercero") @db.VarChar(50)
  nombreTercero String @map("nombre_tercero") @db.VarChar(255)
  telefono  String?  @db.VarChar(20)
  correo    String?  @db.VarChar(255)
  direccion String?  @db.VarChar(255)
  tipo      String   @db.VarChar(50)
  estado    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  entradas Entrada[]
  salidas  Salida[]

  @@map("terceros")
}

model Producto {
  idProducto    String   @id @map("id_producto") @db.VarChar(50)
  nombreProducto String  @map("nombre_producto") @db.VarChar(255)
  marca         String?  @db.VarChar(100)
  precioCompra  Decimal  @map("precio_compra") @db.Decimal(12, 2)
  precioVenta   Decimal  @map("precio_venta") @db.Decimal(12, 2)
  estado        Boolean  @default(true)
  stock         Int      @default(0)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  baseEntradas BaseEntrada[]
  baseSalidas  BaseSalida[]

  @@map("productos")
}

model Entrada {
  numeroEntrada String   @id @map("numero_entrada") @db.VarChar(50)
  fecha         DateTime @default(now()) @db.Timestamp(6)
  proveedor     String?  @map("proveedor") @db.VarChar(50)
  total         Decimal  @default(0) @db.Decimal(12, 2)
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  tercero      Tercero?       @relation(fields: [proveedor], references: [idTercero])
  baseEntradas BaseEntrada[]

  @@map("entradas")
}

model BaseEntrada {
  id                    Int      @id @default(autoincrement())
  numeroEntrada         String   @map("numero_entrada") @db.VarChar(50)
  idProductoEntrada     String   @map("id_producto_entrada") @db.VarChar(50)
  nombreProducto        String   @map("nombre_producto") @db.VarChar(255)
  costoUnitarioEntrada  Decimal  @map("costo_unitario_entrada") @db.Decimal(12, 2)
  unidadesEntradas      Int      @map("unidades_entradas")
  subTotalE             Decimal  @map("sub_total_e") @db.Decimal(12, 2)

  entrada Entrada @relation(fields: [numeroEntrada], references: [numeroEntrada], onDelete: Cascade)
  producto Producto @relation(fields: [idProductoEntrada], references: [idProducto])

  @@map("base_entradas")
}

model Salida {
  numeroSalida String   @id @map("numero_salida") @db.VarChar(50)
  fecha        DateTime @default(now()) @db.Timestamp(6)
  cliente      String?  @map("cliente") @db.VarChar(50)
  total        Decimal  @default(0) @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamp(6)

  tercero     Tercero?     @relation(fields: [cliente], references: [idTercero])
  baseSalidas BaseSalida[]

  @@map("salidas")
}

model BaseSalida {
  id                   Int      @id @default(autoincrement())
  numeroSalida         String   @map("numero_salida") @db.VarChar(50)
  idProductoSalida     String   @map("id_producto_salida") @db.VarChar(50)
  nombreProducto       String   @map("nombre_producto") @db.VarChar(255)
  costoUnitarioSalida  Decimal  @map("costo_unitario_salida") @db.Decimal(12, 2)
  unidadesSalida       Int      @map("unidades_salida")
  subTotalS            Decimal  @map("sub_total_s") @db.Decimal(12, 2)

  salida Salida @relation(fields: [numeroSalida], references: [numeroSalida], onDelete: Cascade)
  producto Producto @relation(fields: [idProductoSalida], references: [idProducto])

  @@map("base_salidas")
}
